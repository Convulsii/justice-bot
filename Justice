# ========== СОБЫТИЯ ==========
@bot.event
async def on_message(msg):
    if msg.author.bot:
        return

    # ========== +rep / -rep ПРИ ОТВЕТЕ НА СООБЩЕНИЕ ==========
    if msg.reference and msg.content:
        try:
            referenced_msg = await msg.channel.fetch_message(msg.reference.message_id)
            target = referenced_msg.author

            if target == msg.author:
                await msg.reply("❌ Нельзя ставить репутацию самому себе!", delete_after=5)
            else:
                content_lower = msg.content.lower().strip()

                if content_lower in ["+rep", "+реп", "++", "👍", "спасибо", "хороший", "молодец", "+", "плюс"]:
                    can, wait = check_rep_cooldown(msg.author.id, target.id)
                    if not can:
                        mins = wait // 60
                        await msg.reply(f"❌ КД! Вы уже меняли репутацию этому пользователю. Подождите {mins} минут", delete_after=10)
                    else:
                        set_rep_cooldown(msg.author.id, target.id)
                        new_rep = await add_reputation(target.id, msg.guild.id, 1)
                        await msg.reply(f"👍 {msg.author.mention} повысил репутацию {target.mention}!\n⭐ Теперь: {new_rep}")
                        embed = discord.Embed(title="👍 +Репутация",
                                              description=f"{msg.author.mention} → {target.mention}\nТеперь: {new_rep}",
                                              color=discord.Color.green())
                        await send_log(msg.guild.id, embed)

                elif content_lower in ["-rep", "-реп", "--", "👎", "плохой", "флудер", "-", "минус"]:
                    can, wait = check_rep_cooldown(msg.author.id, target.id)
                    if not can:
                        mins = wait // 60
                        await msg.reply(f"❌ КД! Вы уже меняли репутацию этому пользователю. Подождите {mins} минут", delete_after=10)
                    else:
                        set_rep_cooldown(msg.author.id, target.id)
                        new_rep = await add_reputation(target.id, msg.guild.id, -1)
                        await msg.reply(f"👎 {msg.author.mention} понизил репутацию {target.mention}!\n⭐ Теперь: {new_rep}")
                        embed = discord.Embed(title="👎 -Репутация",
                                              description=f"{msg.author.mention} → {target.mention}\nТеперь: {new_rep}",
                                              color=discord.Color.red())
                        await send_log(msg.guild.id, embed)
        except Exception as e:
            print(f"Ошибка обработки репутации: {e}")

    # ========== ИИ НА УПОМИНАНИЕ ==========
    if bot.user in msg.mentions:
        clean_text = msg.content.replace(f"<@{bot.user.id}>", "").replace(f"<@!{bot.user.id}>", "").strip()
        if clean_text:
            async with msg.channel.typing():
                response = await get_ai_response(clean_text)
            await msg.reply(response, mention_author=False)
            return

    # ========== ОПЫТ И ДЕНЬГИ ==========
    if random.randint(1, 3) == 1:
        xp_gain = random.randint(10, 25)
        level_up, new_level = await add_xp(msg.author.id, msg.guild.id, xp_gain)
        if level_up:
            settings = guild_settings.get(msg.guild.id, {})
            level_channel_id = settings.get("level_channel", LEVEL_CHANNEL_ID)
            ch = bot.get_channel(level_channel_id)
            if ch:
                await ch.send(f"🎉 {msg.author.mention} достиг {new_level} уровня!")
            if new_level in LEVEL_ROLES:
                role = msg.guild.get_role(LEVEL_ROLES[new_level])
                if role and role not in msg.author.roles:
                    await msg.author.add_roles(role)

    earn = random.randint(MIN_EARN, MAX_EARN)
    await add_balance(msg.author.id, msg.guild.id, earn)

    await bot.process_commands(msg)


